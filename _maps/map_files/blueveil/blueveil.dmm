"liD" = (/obj/item/clothing/armor/plate/blkknight{name = "Drakeleaf Plate"; desc = "Drakeleaf armor, fashioned from the scales of Vezhira herself. To wear it is to bear witness to a feat few could ever hope to accomplish."},/obj/item/clothing/neck/blkknight{name = "Vezhira's Teeth"; desc = "Plucked from the maw of the mighty beast herself, these teeth are still just as sharp as before."},/obj/item/clothing/head/helmet/visored/blkknight{name = "Drakeleaf Helm"; desc = "Drakeleaf armor, fashioned from the scales of Vezhira herself. To wear it is to bear witness to a feat few could ever hope to accomplish."},/obj/item/clothing/gloves/plate/blk{name = "Drakeleaf Gloves"; desc = "Drakeleaf armor, fashioned from the scales of Vezhira herself. To wear it is to bear witness to a feat few could ever hope to accomplish."},/obj/item/clothing/shoes/boots/armor/blkknight{name = "Drakeleaf Boots"; desc = "Drakeleaf armor, fashioned from the scales of Vezhira herself. To wear it is to bear witness to a feat few could ever hope to accomplish."},/obj/item/clothing/pants/platelegs/blk{name = "Drakeleaf Legs"; desc = "Drakeleaf armor, fashioned from the scales of Vezhira herself. To wear it is to bear witness to a feat few could ever hope to accomplish."},/obj/item/weapon/sword/long/death{desc = "Vezhira's bone adorns this blade, its strength empowering each swing."; name = "Vezhira's Spine"},/mob/living/simple_animal/hostile/retaliate/voiddragon/red/tsere{name = "Vezhira, Hoarder of Souls"; desc = "From the crypts of Velazur she emerged, crimson-winged and death-sworn. This hulking abomination of rotting flesh and exposed bone shambles forward in Zizo's name. The cult that summoned her vanished into her maw, and the city beyond became her ambition. This is Vezhira... Hoarder of Souls."},/turf/open/floor/church/violet,/area/indoors/vampire_manor{first_time_text = "ZIZO'S CHAPEL"})
